{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["electron/**/*.ts", "shared/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "dist/**",
    "dist-electron/**",
    ".worktrees/**",
    "node_modules/**"
  ]
}
