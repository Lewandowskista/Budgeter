{
  "name": "budgeter",
  "version": "1.0.0",
  "description": "Personal budgeting desktop app",
  "author": "Stefan",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "rebuild:native:electron": "node scripts/rebuild-electron-native.cjs",
    "rebuild:native:node": "npm rebuild better-sqlite3",
    "predev": "npm run rebuild:native:electron",
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist-electron/electron/main.js && set ELECTRON_RUN_AS_NODE=&& .\\node_modules\\electron\\dist\\electron.exe .\"",
    "prebuild": "npm run rebuild:native:electron",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "test": "node scripts/run-vitest-with-native-rebuild.cjs",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "prepackage": "npm run rebuild:native:electron",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.48.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.stefan.budgeter",
    "productName": "Budgeter",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    }
  }
}
